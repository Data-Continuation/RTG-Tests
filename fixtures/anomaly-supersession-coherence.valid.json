      "anomaly_resolved": false,
      "risk": 0.8,
      "expected_state": "supersession_quarantine_anomaly"
    },
    {
      "case_id": "ASC-004",
      "new_version": 1,
      "prior_version": 2,
      "anomaly_present": true,
      "anomaly_resolved": true,
      "risk": 0.2,
      "expected_state": "older_anomaly_attempt_blocked"
    },
    {
      "case_id": "ASC-005",
      "new_version": 3,
      "prior_version": 2,
      "anomaly_present": false,
      "anomaly_resolved": false,
