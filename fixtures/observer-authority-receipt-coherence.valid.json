      "observer_compatible": false,
      "authority_satisfied": true,
      "receipt_present": true,
      "receipt_conflict": false,
      "expected_state": "observer_incompatible"
    },
    {
      "case_id": "OAR-003",
      "observer_compatible": true,
      "authority_satisfied": false,
      "receipt_present": true,
      "receipt_conflict": false,
      "expected_state": "authority_missing"
    },
    {
      "case_id": "OAR-004",
      "observer_compatible": true,
      "authority_satisfied": true,
      "receipt_present": false,
      "receipt_conflict": false,
      "expected_state": "receipt_missing"
    },
    {
      "case_id": "OAR-005",
      "observer_compatible": true,
      "authority_satisfied": false,
      "receipt_present": true,
      "receipt_conflict": true,
      "expected_state": "receipt_authority_quarantine"
