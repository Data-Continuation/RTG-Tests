{
  "schema_version": "1.0",
  "maturity": "provisional",
  "principle": "A transition claim must be replayable or receipt-consistent before it can become valid state evidence.",
  "valid_replay_states": [
    "valid_replay",
    "receipt_consistent",
    "replay_required",
    "receipt_conflict",
    "invalid_replay",
    "unreplayable_provisional"
  ],
  "governance_outputs": {
    "valid_replay": "accept_state_evidence",
    "receipt_consistent": "accept_with_receipt_basis",
    "replay_required": "defer_require_replay",
    "receipt_conflict": "quarantine_receipt_conflict",
    "invalid_replay": "reject_invalid_replay",
    "unreplayable_provisional": "mark_provisional_preserve_anomaly"
  },
  "thresholds": {
    "hash_match_required": true,
    "receipt_consistency_min": 0.8,
