{
  "schema_version": "1.0",
  "maturity": "provisional",
  "test_key": "multi_observer_consensus_coherence",
  "layer_type": "cross-layer coherence",
  "title": "Multi Observer Consensus Coherence",
  "valid_states": [
    "consensus_accept",
    "consensus_defer",
    "consensus_reject",
    "minority_report_preserved",
    "consensus_quarantine"
  ],
  "cases": [
    {
      "case_id": "MOC-001",
      "compatible_observers": 3,
