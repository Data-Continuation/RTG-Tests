      "reject_votes": 0,
      "quarantine_signal": false,
      "expected_state": "consensus_accept"
    },
    {
      "case_id": "MOC-002",
      "compatible_observers": 1,
      "required_observers": 2,
      "reject_votes": 0,
      "quarantine_signal": false,
      "expected_state": "consensus_defer"
    },
    {
      "case_id": "MOC-003",
      "compatible_observers": 3,
      "required_observers": 2,
      "reject_votes": 2,
      "quarantine_signal": false,
      "expected_state": "consensus_reject"
    },
    {
      "case_id": "MOC-004",
      "compatible_observers": 3,
      "required_observers": 2,
      "reject_votes": 1,
      "quarantine_signal": false,
      "expected_state": "minority_report_preserved"
    },
    {
      "case_id": "MOC-005",
      "compatible_observers": 3,
      "required_observers": 2,
      "reject_votes": 0,
      "quarantine_signal": true,
      "expected_state": "consensus_quarantine"
